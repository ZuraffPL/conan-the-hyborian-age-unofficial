{{!-- Minion Actor Sheet --}}
<form class="{{cssClass}} flexcol" autocomplete="off">
  {{!-- Sheet Header --}}
  <header class="sheet-header">
    <img class="profile-img" src="{{actor.img}}" data-action="editImage" title="{{actor.name}}" alt="{{actor.name}}" />
    
    <div class="header-fields">
      <h1 class="charname">
        <input name="name" type="text" value="{{actor.name}}" placeholder="{{localize 'CONAN.CharacterName'}}" />
      </h1>
      
      <div class="actor-type-row">
        <div class="actor-type-label">
          <span class="primary-label">{{localize "TYPES.Actor.minion"}}</span>
          <span class="subtitle-label">Minion</span>
        </div>
        
        <div class="creature-type-field">
          <label>
            <span class="primary-label">{{localize "CONAN.Common.type"}}</span>
            <span class="subtitle-label">Creature Type</span>
          </label>
          <select name="system.creatureType" data-dtype="String">
            <option value="human" {{#if (eq system.creatureType "human")}}selected{{/if}}>{{localize "CONAN.CreatureTypes.human"}} / Human</option>
            <option value="inanimate" {{#if (eq system.creatureType "inanimate")}}selected{{/if}}>{{localize "CONAN.CreatureTypes.inanimate"}} / Inanimate</option>
            <option value="undead" {{#if (eq system.creatureType "undead")}}selected{{/if}}>{{localize "CONAN.CreatureTypes.undead"}} / Undead</option>
            <option value="monstrosity" {{#if (eq system.creatureType "monstrosity")}}selected{{/if}}>{{localize "CONAN.CreatureTypes.monstrosity"}} / Monstrosity</option>
            <option value="demon" {{#if (eq system.creatureType "demon")}}selected{{/if}}>{{localize "CONAN.CreatureTypes.demon"}} / Demon</option>
            <option value="beast" {{#if (eq system.creatureType "beast")}}selected{{/if}}>{{localize "CONAN.CreatureTypes.beast"}} / Beast</option>
          </select>
        </div>
      </div>
    </div>
  </header>

  {{!-- Sheet Body --}}
  <section class="sheet-body">
    {{!-- Tabs Navigation --}}
    <nav class="sheet-tabs tabs" data-group="primary">
      <a class="item" data-tab="stats">
        <i class="fas fa-chart-bar"></i> {{localize "CONAN.NPC.tabStats"}}
      </a>
      <a class="item" data-tab="powers">
        <i class="fas fa-magic"></i> {{localize "CONAN.NPC.tabPowers"}}
      </a>
    </nav>

    {{!-- Tab: Statistics --}}
    <div class="tab" data-group="primary" data-tab="stats">
      {{!-- Attributes Section --}}
      <div class="attributes-section">
      <h3 class="section-header">{{localize "CONAN.CharacterSheet.attributes"}} / Attributes</h3>
      
      <div class="attributes-row">
        <div class="attribute-box" data-attribute="might">
          <div class="attribute-header">
            <span class="attribute-abbr">{{localize "CONAN.Attributes.might.abbr"}}</span>
            <span class="attribute-label">{{localize "CONAN.Attributes.might.label"}}</span>
          </div>
          <div class="attribute-values">
            <input type="number" name="system.attributes.might.value" value="{{system.attributes.might.value}}" min="1" max="20" data-dtype="Number" class="attribute-value" />
            <select name="system.attributes.might.die" data-dtype="String" class="attribute-die">
              <option value="d4" {{#if (eq system.attributes.might.die "d4")}}selected{{/if}}>d4</option>
              <option value="d6" {{#if (eq system.attributes.might.die "d6")}}selected{{/if}}>d6</option>
              <option value="d8" {{#if (eq system.attributes.might.die "d8")}}selected{{/if}}>d8</option>
              <option value="d10" {{#if (eq system.attributes.might.die "d10")}}selected{{/if}}>d10</option>
              <option value="d12" {{#if (eq system.attributes.might.die "d12")}}selected{{/if}}>d12</option>
            </select>
          </div>
          <button type="button" class="attribute-mod" data-action="rollAttribute" data-attribute="might" title="{{localize 'CONAN.Common.roll'}}">
            <i class="fas fa-dice-d20"></i>
            {{localize 'CONAN.Common.roll'}}
          </button>
        </div>
        <div class="attribute-box" data-attribute="edge">
          <div class="attribute-header">
            <span class="attribute-abbr">{{localize "CONAN.Attributes.edge.abbr"}}</span>
            <span class="attribute-label">{{localize "CONAN.Attributes.edge.label"}}</span>
          </div>
          <div class="attribute-values">
            <input type="number" name="system.attributes.edge.value" value="{{system.attributes.edge.value}}" min="1" max="20" data-dtype="Number" class="attribute-value" />
            <select name="system.attributes.edge.die" data-dtype="String" class="attribute-die">
              <option value="d4" {{#if (eq system.attributes.edge.die "d4")}}selected{{/if}}>d4</option>
              <option value="d6" {{#if (eq system.attributes.edge.die "d6")}}selected{{/if}}>d6</option>
              <option value="d8" {{#if (eq system.attributes.edge.die "d8")}}selected{{/if}}>d8</option>
              <option value="d10" {{#if (eq system.attributes.edge.die "d10")}}selected{{/if}}>d10</option>
              <option value="d12" {{#if (eq system.attributes.edge.die "d12")}}selected{{/if}}>d12</option>
            </select>
          </div>
          <button type="button" class="attribute-mod" data-action="rollAttribute" data-attribute="edge" title="{{localize 'CONAN.Common.roll'}}">
            <i class="fas fa-dice-d20"></i>
            {{localize 'CONAN.Common.roll'}}
          </button>
        </div>
        <div class="attribute-box" data-attribute="grit">
          <div class="attribute-header">
            <span class="attribute-abbr">{{localize "CONAN.Attributes.grit.abbr"}}</span>
            <span class="attribute-label">{{localize "CONAN.Attributes.grit.label"}}</span>
          </div>
          <div class="attribute-values">
            <input type="number" name="system.attributes.grit.value" value="{{system.attributes.grit.value}}" min="1" max="20" data-dtype="Number" class="attribute-value" />
            <select name="system.attributes.grit.die" data-dtype="String" class="attribute-die">
              <option value="d4" {{#if (eq system.attributes.grit.die "d4")}}selected{{/if}}>d4</option>
              <option value="d6" {{#if (eq system.attributes.grit.die "d6")}}selected{{/if}}>d6</option>
              <option value="d8" {{#if (eq system.attributes.grit.die "d8")}}selected{{/if}}>d8</option>
              <option value="d10" {{#if (eq system.attributes.grit.die "d10")}}selected{{/if}}>d10</option>
              <option value="d12" {{#if (eq system.attributes.grit.die "d12")}}selected{{/if}}>d12</option>
            </select>
          </div>
          <button type="button" class="attribute-mod" data-action="rollAttribute" data-attribute="grit" title="{{localize 'CONAN.Common.roll'}}">
            <i class="fas fa-dice-d20"></i>
            {{localize 'CONAN.Common.roll'}}
          </button>
        </div>
        <div class="attribute-box" data-attribute="wits">
          <div class="attribute-header">
            <span class="attribute-abbr">{{localize "CONAN.Attributes.wits.abbr"}}</span>
            <span class="attribute-label">{{localize "CONAN.Attributes.wits.label"}}</span>
          </div>
          <div class="attribute-values">
            <input type="number" name="system.attributes.wits.value" value="{{system.attributes.wits.value}}" min="1" max="20" data-dtype="Number" class="attribute-value" />
            <select name="system.attributes.wits.die" data-dtype="String" class="attribute-die">
              <option value="d4" {{#if (eq system.attributes.wits.die "d4")}}selected{{/if}}>d4</option>
              <option value="d6" {{#if (eq system.attributes.wits.die "d6")}}selected{{/if}}>d6</option>
              <option value="d8" {{#if (eq system.attributes.wits.die "d8")}}selected{{/if}}>d8</option>
              <option value="d10" {{#if (eq system.attributes.wits.die "d10")}}selected{{/if}}>d10</option>
              <option value="d12" {{#if (eq system.attributes.wits.die "d12")}}selected{{/if}}>d12</option>
            </select>
          </div>
          <button type="button" class="attribute-mod" data-action="rollAttribute" data-attribute="wits" title="{{localize 'CONAN.Common.roll'}}">
            <i class="fas fa-dice-d20"></i>
            {{localize 'CONAN.Common.roll'}}
          </button>
        </div>
      </div>
      </div>

      {{!-- Defense and Threshold Section --}}
      <div class="defense-section">
      <h3 class="section-header">{{localize "CONAN.NPC.defenseThreshold"}} / Defence & Threshold</h3>
      
      <div class="defense-row">
        <div class="defense-box">
          <div class="defense-header">
            <span class="defense-abbr">{{localize "CONAN.Resources.physical"}}</span>
            <span class="defense-label">Physical Defence</span>
          </div>
          
          <div class="defense-value-container {{#if system.defenceActive}}defence-active{{/if}} {{#if system.immobilized}}immobilized-active{{/if}}">
            <input type="number" name="system.defense.physical" value="{{system.defense.physical}}" min="0" max="20" data-dtype="Number" class="defense-value {{#if system.immobilized}}immobilized{{/if}}" />
            <div class="defense-indicators">
              {{#if system.defenceActive}}
                <span class="defence-bonus">+2</span>
              {{/if}}
              {{#if system.immobilized}}
                <span class="immobilized-indicator">0</span>
              {{/if}}
            </div>
          </div>
        </div>

        <div class="defense-box">
          <div class="defense-header">
            <span class="defense-abbr">{{localize "CONAN.Resources.sorcery"}}</span>
            <span class="defense-label">Sorcery Defence</span>
          </div>
          
          <input type="number" name="system.defense.sorcery" value="{{system.defense.sorcery}}" min="0" max="20" data-dtype="Number" class="defense-value" />
        </div>

        <div class="defense-box">
          <div class="defense-header">
            <span class="defense-abbr">{{localize "CONAN.NPC.threshold"}}</span>
            <span class="defense-label">Threshold</span>
          </div>
          
          <input type="number" name="system.threshold" value="{{system.threshold}}" min="1" max="25" data-dtype="Number" class="defense-value" />
        </div>

        <div class="defense-box">
          <div class="defense-header">
            <span class="defense-abbr">{{localize "CONAN.NPC.armor"}}</span>
            <span class="defense-label">Armor ({{localize "CONAN.NPC.armorAbbr"}})</span>
          </div>
          
          <input type="number" name="system.armor" value="{{system.armor}}" min="0" max="20" data-dtype="Number" class="defense-value" />
        </div>

        <div class="defense-box wounded-box">
          <label class="wounded-checkbox">
            <input type="checkbox" name="system.wounded" {{#if system.wounded}}checked{{/if}} data-dtype="Boolean" data-action="toggleWounded" />
            <span class="wounded-label">
              <span class="primary-label">{{localize "CONAN.NPC.wounded"}}</span>
              <span class="subtitle-label">Wounded</span>
            </span>
            <i class="fas fa-heart-broken wounded-icon"></i>
          </label>
        </div>
      </div>
      </div>

      {{!-- Threat Engine Section --}}
      <div class="threat-engine-section">
        <div class="threat-engine-header">
          <button type="button" class="threat-engine-collapse">
            <i class="fas fa-chevron-right threat-chevron"></i>
            <span class="section-header">{{localize "CONAN.ThreatEngine.title"}}</span>
          </button>
          <label class="threat-engine-toggle" title="{{localize 'CONAN.ThreatEngine.enabledHint'}}">
            <input type="checkbox" name="system.threatEngineEnabled" {{#if system.threatEngineEnabled}}checked{{/if}} data-dtype="Boolean" />
            <span>{{localize "CONAN.ThreatEngine.enabled"}}</span>
          </label>
        </div>

        <div class="threat-engine-content">
          <p class="threat-engine-info">{{localize "CONAN.ThreatEngine.probabilities"}}</p>
          <div class="threat-ranges-table">
            <div class="threat-ranges-header">
              <span class="thr-stat-label"></span>
              <span class="thr-col thr-weak">{{localize "CONAN.ThreatEngine.tierWeak"}}</span>
              <span class="thr-col thr-strong">{{localize "CONAN.ThreatEngine.tierStrong"}} 💀</span>
              <span class="thr-col thr-elite">{{localize "CONAN.ThreatEngine.tierElite"}} 💀💀</span>
            </div>
            <div class="threat-range-row">
              <span class="thr-stat-label">{{localize "CONAN.Defense.physical"}}</span>
              <span class="thr-preview">{{threatPreview.physical.weak}}</span>
              <span class="thr-preview tier-strong">{{threatPreview.physical.strong}}</span>
              <span class="thr-preview tier-elite">{{threatPreview.physical.elite}}</span>
            </div>
            <div class="threat-range-row">
              <span class="thr-stat-label">{{localize "CONAN.Defense.sorcery"}}</span>
              <span class="thr-preview">{{threatPreview.sorcery.weak}}</span>
              <span class="thr-preview tier-strong">{{threatPreview.sorcery.strong}}</span>
              <span class="thr-preview tier-elite">{{threatPreview.sorcery.elite}}</span>
            </div>
            <div class="threat-range-row">
              <span class="thr-stat-label">{{localize "CONAN.NPC.armor"}}</span>
              <span class="thr-preview">{{threatPreview.armor.weak}}</span>
              <span class="thr-preview tier-strong">{{threatPreview.armor.strong}}</span>
              <span class="thr-preview tier-elite">{{threatPreview.armor.elite}}</span>
            </div>
          </div>
        </div>
      </div>

      {{!-- Damage and Actions Section --}}
      <div class="damage-actions-container">
        {{!-- Damage Section --}}
        <div class="damage-section">
          <h3 class="section-header">{{localize "CONAN.NPC.damage"}} / Damage</h3>

        {{#each system.damage}}
        <div class="damage-row" data-index="{{@index}}">
          <div class="damage-row-header">
            <select name="system.damage.{{@index}}.type" data-dtype="String" class="damage-type-select">
              <option value="melee" {{#if (eq type "melee")}}selected{{/if}}>{{localize "CONAN.NPC.meleeDamage"}}</option>
              <option value="ranged" {{#if (eq type "ranged")}}selected{{/if}}>{{localize "CONAN.NPC.rangedDamage"}}</option>
            </select>
            <button type="button" class="npc-attack-btn {{#if (and @root.system.poisoned @root.system.poisonEffects.effect2)}}poisoned-penalty{{/if}}" data-action="npcAttack" data-attack-index="{{@index}}" title="{{localize 'CONAN.Attack.rollAttack'}}">
              <i class="fas fa-sword"></i>
              {{#if (and @root.system.poisoned @root.system.poisonEffects.effect2)}}
                <i class="fas fa-skull-crossbones poison-icon" style="color: #15a20e; font-size: 0.8em; margin-left: 4px;"></i>
              {{/if}}
            </button>
            <button type="button" class="npc-damage-btn {{#if (and @root.system.poisoned @root.system.poisonEffects.effect2)}}poisoned-penalty{{/if}}" data-action="npcDamage" data-attack-index="{{@index}}" title="{{localize 'CONAN.Damage.rollDamage'}}">
              <img src="systems/conan-the-hyborian-age/assets/icons/damage.svg" alt="{{localize 'CONAN.Damage.rollDamage'}}" />
              {{#if (and @root.system.poisoned @root.system.poisonEffects.effect2)}}
                <i class="fas fa-skull-crossbones poison-icon" style="color: #15a20e; font-size: 0.8em; margin-left: 4px;"></i>
              {{/if}}
            </button>
            <button type="button" class="remove-attack-btn" data-action="removeAttack" data-index="{{@index}}" title="{{localize 'CONAN.Common.delete'}}">
              <i class="fas fa-trash"></i>
            </button>
          </div>
          <div class="damage-fields">
            <input type="text" name="system.damage.{{@index}}.name" value="{{name}}" placeholder="{{localize 'CONAN.NPC.weaponName'}}" class="damage-name" />
            
            <select name="system.damage.{{@index}}.die" data-dtype="String" class="damage-die">
              <option value="d4" {{#if (eq die "d4")}}selected{{/if}}>d4</option>
              <option value="d6" {{#if (eq die "d6")}}selected{{/if}}>d6</option>
              <option value="d8" {{#if (eq die "d8")}}selected{{/if}}>d8</option>
              <option value="d10" {{#if (eq die "d10")}}selected{{/if}}>d10</option>
              <option value="d12" {{#if (eq die "d12")}}selected{{/if}}>d12</option>
            </select>
            
            <input type="number" name="system.damage.{{@index}}.modifier" value="{{modifier}}" min="0" max="15" data-dtype="Number" class="damage-modifier" />
          </div>
        </div>
        {{/each}}

        <div class="add-attack-buttons">
          <button type="button" class="add-attack-btn" data-action="addAttack" data-type="melee">
            <i class="fas fa-plus"></i> {{localize "CONAN.NPC.meleeDamage"}}
          </button>
          <button type="button" class="add-attack-btn" data-action="addAttack" data-type="ranged">
            <i class="fas fa-plus"></i> {{localize "CONAN.NPC.rangedDamage"}}
          </button>
        </div>
        </div>
      
        {{!-- Right Column: Actions + Effects --}}
        <div class="right-column">
          {{!-- Actions Section --}}
          <div class="actions-section">
            <h3 class="section-header">{{localize "CONAN.NPC.actions"}} / Actions & Attacks</h3>
          
          <div class="action-field">
            <label>
              <span class="primary-label">{{localize "CONAN.NPC.actionsPerRound"}}</span>
              <span class="subtitle-label">Actions per Round</span>
            </label>
            <input type="number" name="system.actions.perRound" value="{{system.actions.perRound}}" min="1" max="10" data-dtype="Number" class="action-value" />
          </div>
          
          <div class="action-field">
            <label>
              <span class="primary-label">{{localize "CONAN.NPC.attacksPerRound"}}</span>
              <span class="subtitle-label">Attacks per Round</span>
            </label>
            <input type="number" name="system.actions.attacks" value="{{system.actions.attacks}}" min="1" max="10" data-dtype="Number" class="action-value" />
          </div>
          </div>
          
          {{!-- Effects Section --}}
          <div class="effects-section">
            <h3 class="section-header">{{localize "CONAN.NPC.effects"}} / Effects</h3>
            
            <div class="effects-row">
              <button type="button" class="defence-toggle-btn {{#if system.defenceActive}}active{{/if}}" data-action="toggleDefence" title="{{localize 'CONAN.EffectTooltips.defence'}}">
                <i class="fas fa-shield-alt"></i>
              </button>
              
              <button type="button" class="immobilized-toggle-btn {{#if system.immobilized}}active{{/if}}" data-action="toggleImmobilized" title="{{localize 'CONAN.EffectTooltips.immobilized'}}">
                <img src="systems/conan-the-hyborian-age/assets/icons/paralysis.svg" alt="Immobilized" />
              </button>
              
              <div style="position: relative; display: inline-block;">
                {{#if (and system.poisoned (gt activePoisonEffects 0))}}
                  <span class="poison-effect-count">{{activePoisonEffects}}</span>
                {{/if}}
                <button type="button" class="poisoned-toggle-btn {{#if system.poisoned}}active{{/if}}" data-action="togglePoisoned" title="{{localize 'CONAN.EffectTooltips.poisoned'}}">
                  <img src="systems/conan-the-hyborian-age/assets/icons/Poisoned.svg" alt="Poisoned" />
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    {{!-- End Tab: Statistics --}}

    {{!-- Tab: Powers and Special Rules --}}
    <div class="tab" data-group="primary" data-tab="powers">
      <h3 class="section-header">{{localize "CONAN.NPC.powersAndRules"}} / Powers & Special Rules</h3>
      
      <div class="powers-section">
        <div class="powers-subsection">
          <h4 class="subsection-header">
            <i class="fas fa-magic"></i> {{localize "CONAN.NPC.magicPowers"}}
          </h4>
          <textarea name="system.powers.magic" rows="5" class="auto-resize-powers" placeholder="{{localize 'CONAN.NPC.magicPowersPlaceholder'}}">{{system.powers.magic}}</textarea>
        </div>
        
        <div class="powers-separator"></div>
        
        <div class="powers-subsection">
          <h4 class="subsection-header">
            <i class="fas fa-bolt"></i> {{localize "CONAN.NPC.specialActions"}}
          </h4>
          <textarea name="system.powers.special" rows="5" class="auto-resize-powers" placeholder="{{localize 'CONAN.NPC.specialActionsPlaceholder'}}">{{system.powers.special}}</textarea>
        </div>
      </div>
    </div>
    {{!-- End Tab: Powers --}}
  </section>
</form>